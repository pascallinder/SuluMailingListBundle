            xsi:schemaLocation="http://schemas.sulu.io/template/template http://schemas.sulu.io/template/template-1.0.xsd">
    <property name="name" type="single_select" multilingual="false" mandatory="true">
        <meta>
            <title>mailingListMail.props.content.social.element.name</title>
