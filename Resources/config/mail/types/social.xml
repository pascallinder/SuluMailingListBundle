        <meta>
            <title>mailingListMail.props.content.social.iconSize</title>
        </meta>
        <params>
            <param name="min" value="0"/>
            <param name="max" value="100"/>
            <param name="step" value="1"/>
            <param name="default" value="16" />
        </params>
    </property>
    <xi:include href="../grouped-props/text-props.xml"
