                      xpointer(/sulu:properties/sulu:property)"/>
                    <xi:include href="../props/url.xml"
                                xpointer="xmlns(sulu=http://schemas.sulu.io/template/template)
                      xpointer(/sulu:properties/sulu:property)"/>
                    <property name="label" type="text_line">
                        <meta>
                            <title>mailingListMail.props.content.social.element.elementLabel</title>
                        </meta>
                    </property>
                    <xi:include href="../props/position.xml"
                                xpointer="xmlns(sulu=http://schemas.sulu.io/template/template)
                      xpointer(/sulu:properties/sulu:property)"/>

                    <xi:include href="../props/background-color.xml"
                                xpointer="xmlns(sulu=http://schemas.sulu.io/template/template)
                      xpointer(/sulu:properties/sulu:property)"/>

                </properties>
            </type>
        </types>
    </property>
    <xi:include href="../props/mode.xml"
                xpointer="xmlns(sulu=http://schemas.sulu.io/template/template)
                      xpointer(/sulu:properties/sulu:property)"/>
    <xi:include href="../props/align.xml"
                xpointer="xmlns(sulu=http://schemas.sulu.io/template/template)
                      xpointer(/sulu:properties/sulu:property)"/>
